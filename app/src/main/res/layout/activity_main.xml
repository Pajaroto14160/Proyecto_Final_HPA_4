<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_50">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragmentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="0dp"
        android:layout_height="76dp"
        android:background="@color/white"
        android:elevation="12dp"
        android:orientation="horizontal"
        android:paddingBottom="3dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <View
                android:layout_width="34dp"
                android:layout_height="3dp"
                android:background="@color/nav_indicator_color"
                android:duplicateParentState="true" />

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginTop="8dp"
                android:contentDescription="Inicio"
                android:duplicateParentState="true"
                android:src="@drawable/ic_home"
                app:tint="@color/nav_item_color" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:autoSizeMaxTextSize="10sp"
                android:autoSizeMinTextSize="7sp"
                android:autoSizeStepGranularity="1sp"
                android:autoSizeTextType="uniform"
                android:duplicateParentState="true"
                android:ellipsize="none"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:paddingHorizontal="2dp"
                android:text="Inicio"
                android:textColor="@color/nav_item_color"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_appointments"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <View
                android:layout_width="34dp"
                android:layout_height="3dp"
                android:background="@color/nav_indicator_color"
                android:duplicateParentState="true" />

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginTop="8dp"
                android:contentDescription="Citas"
                android:duplicateParentState="true"
                android:src="@drawable/ic_calendar"
                app:tint="@color/nav_item_color" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:autoSizeMaxTextSize="10sp"
                android:autoSizeMinTextSize="7sp"
                android:autoSizeStepGranularity="1sp"
                android:autoSizeTextType="uniform"
                android:duplicateParentState="true"
                android:ellipsize="none"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:paddingHorizontal="2dp"
                android:text="Citas"
                android:textColor="@color/nav_item_color"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_history"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <View
                android:layout_width="34dp"
                android:layout_height="3dp"
                android:background="@color/nav_indicator_color"
                android:duplicateParentState="true" />

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginTop="8dp"
                android:contentDescription="Historial"
                android:duplicateParentState="true"
                android:src="@drawable/ic_history"
                app:tint="@color/nav_item_color" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:autoSizeMaxTextSize="10sp"
                android:autoSizeMinTextSize="7sp"
                android:autoSizeStepGranularity="1sp"
                android:autoSizeTextType="uniform"
                android:duplicateParentState="true"
                android:ellipsize="none"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:paddingHorizontal="2dp"
                android:text="Historial"
                android:textColor="@color/nav_item_color"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_medications"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <View
                android:layout_width="34dp"
                android:layout_height="3dp"
                android:background="@color/nav_indicator_color"
                android:duplicateParentState="true" />

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginTop="8dp"
                android:contentDescription="Medicamentos"
                android:duplicateParentState="true"
                android:src="@drawable/ic_medication"
                app:tint="@color/nav_item_color" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:autoSizeMaxTextSize="10sp"
                android:autoSizeMinTextSize="7sp"
                android:autoSizeStepGranularity="1sp"
                android:autoSizeTextType="uniform"
                android:duplicateParentState="true"
                android:ellipsize="none"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:paddingHorizontal="1dp"
                android:text="Medicamentos"
                android:textColor="@color/nav_item_color"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_locations"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <View
                android:layout_width="34dp"
                android:layout_height="3dp"
                android:background="@color/nav_indicator_color"
                android:duplicateParentState="true" />

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginTop="8dp"
                android:contentDescription="Mapas"
                android:duplicateParentState="true"
                android:src="@drawable/ic_map"
                app:tint="@color/nav_item_color" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:autoSizeMaxTextSize="10sp"
                android:autoSizeMinTextSize="7sp"
                android:autoSizeStepGranularity="1sp"
                android:autoSizeTextType="uniform"
                android:duplicateParentState="true"
                android:ellipsize="none"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:paddingHorizontal="2dp"
                android:text="Mapas"
                android:textColor="@color/nav_item_color"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
