<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_50"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="154dp"
            android:background="@drawable/bg_header_gradient">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="top"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="24dp"
                android:paddingTop="28dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Buenos días,"
                        android:textColor="#C8FFFFFF"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Paciente"
                        android:textColor="@color/white"
                        android:textSize="23sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvInitials"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:background="@drawable/bg_avatar"
                    android:gravity="center"
                    android:text="MC"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:layout_gravity="bottom"
                android:background="@drawable/bg_white_rounded_top" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="24dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardNextAppointment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-10dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="5dp"
                app:strokeColor="@color/teal_100"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="match_parent"
                        android:background="@color/teal_400" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PRÓXIMA CITA"
                            android:textColor="@color/teal_600"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvNextTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:text="Cardiología"
                            android:textColor="@color/gray_800"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvNextSubtitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Dr. Ricardo Medina · Hospital Santo Tomás"
                            android:textColor="@color/gray_500"
                            android:textSize="13sp" />

                        <LinearLayout
                            android:id="@+id/groupNextDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tvNextDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_chip_teal"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="6dp"
                                android:text="22 Ago 2026"
                                android:textColor="@color/teal_700"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvNextTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_chip_teal"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="6dp"
                                android:text="10:30"
                                android:textColor="@color/teal_700"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvNoAppointment"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="No tienes citas próximas."
                            android:textColor="@color/gray_500"
                            android:textSize="14sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Módulos"
                android:textAppearance="@style/TextAppearance.MediConecta.Section" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAppointments"
                    android:layout_width="0dp"
                    android:layout_height="132dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeColor="@color/teal_100"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <FrameLayout android:layout_width="46dp" android:layout_height="46dp" android:background="@drawable/bg_module_blue" android:padding="11dp">
                            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:src="@drawable/ic_calendar" android:contentDescription="Citas" />
                        </FrameLayout>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:gravity="center" android:maxLines="1" android:text="Citas" android:textAlignment="center" android:textColor="@color/gray_800" android:textSize="15sp" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardHistory"
                    android:layout_width="0dp"
                    android:layout_height="132dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeColor="@color/teal_100"
                    app:strokeWidth="1dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical" android:padding="12dp">
                        <FrameLayout android:layout_width="46dp" android:layout_height="46dp" android:background="@drawable/bg_module_amber" android:padding="11dp">
                            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:src="@drawable/ic_history" android:contentDescription="Historial" />
                        </FrameLayout>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:gravity="center" android:maxLines="1" android:text="Historial" android:textAlignment="center" android:textColor="@color/gray_800" android:textSize="15sp" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardMedications"
                    android:layout_width="0dp"
                    android:layout_height="132dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeColor="@color/teal_100"
                    app:strokeWidth="1dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical" android:padding="12dp">
                        <FrameLayout android:layout_width="46dp" android:layout_height="46dp" android:background="@drawable/bg_module_purple" android:padding="11dp">
                            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:src="@drawable/ic_medication" android:contentDescription="Medicamentos" />
                        </FrameLayout>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:gravity="center" android:maxLines="1" android:text="Medicamentos" android:textAlignment="center" android:textColor="@color/gray_800" android:textSize="15sp" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardLocations"
                    android:layout_width="0dp"
                    android:layout_height="132dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeColor="@color/teal_100"
                    app:strokeWidth="1dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical" android:padding="12dp">
                        <FrameLayout android:layout_width="46dp" android:layout_height="46dp" android:background="@drawable/bg_module_teal" android:padding="11dp">
                            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:src="@drawable/ic_map" android:contentDescription="Mapas" />
                        </FrameLayout>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:gravity="center" android:maxLines="1" android:text="Mapas" android:textAlignment="center" android:textColor="@color/gray_800" android:textSize="15sp" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Acceso rápido"
                android:textAppearance="@style/TextAppearance.MediConecta.Section" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="8dp">

                <TextView
                    android:id="@+id/quickMedications"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="\nVer medicamentos"
                    android:textAlignment="center"
                    android:textColor="@color/gray_600"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <View android:layout_width="1dp" android:layout_height="56dp" android:background="@color/gray_100" />

                <TextView
                    android:id="@+id/quickNewAppointment"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="\nNueva cita"
                    android:textAlignment="center"
                    android:textColor="@color/gray_600"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <View android:layout_width="1dp" android:layout_height="56dp" android:background="@color/gray_100" />

                <TextView
                    android:id="@+id/quickLocations"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="\nHospitales"
                    android:textAlignment="center"
                    android:textColor="@color/gray_600"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
