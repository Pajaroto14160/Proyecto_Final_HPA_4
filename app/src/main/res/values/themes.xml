<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.MediConecta" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/teal_600</item>
        <item name="colorPrimaryVariant">@color/teal_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_500</item>
        <item name="colorSecondaryVariant">@color/teal_600</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:fontFamily">sans</item>
        <item name="fontFamily">sans</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:statusBarColor">@color/teal_600</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:windowActionModeOverlay">true</item>
        <item name="materialButtonStyle">@style/Widget.MediConecta.Button</item>
        <item name="textInputStyle">@style/Widget.MediConecta.TextInputLayout</item>
    </style>

    <style name="Widget.MediConecta.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:minHeight">52dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">15sp</item>
        <item name="backgroundTint">@color/teal_500</item>
    </style>

    <style name="Widget.MediConecta.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:minHeight">52dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">15sp</item>
        <item name="strokeColor">@color/teal_300</item>
        <item name="android:textColor">@color/teal_700</item>
    </style>

    <style name="Widget.MediConecta.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/gray_50</item>
        <item name="boxStrokeColor">@color/teal_500</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="hintTextColor">@color/gray_500</item>
    </style>

    <style name="TextAppearance.MediConecta.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/gray_800</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">20sp</item>
    </style>

    <style name="TextAppearance.MediConecta.Section" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textColor">@color/gray_700</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">14sp</item>
    </style>
</resources>
